{
  "name": "@trustmodel/mcp-server",
  "version": "0.1.0",
  "description": "TrustModel MCP Server — trust evaluation for AI agents via Model Context Protocol",
  "type": "module",
  "bin": {
    "trustmodel-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "verify:scanner": "npm run build && node scripts/verify-scanner.mjs",
    "verify:discovery": "npm run build && node scripts/verify-shadow-discovery.mjs",
    "verify:fingerprint": "npm run build && node scripts/verify-fingerprint.mjs",
    "verify:error-envelope": "npm run build && node scripts/verify-error-envelope.mjs",
    "regression:scanner": "npm run build && node regression/scanner.mjs",
    "smoke": "npm run build && node e2e/smoke.mjs"
  },
  "keywords": [
    "mcp",
    "trustmodel",
    "ai-safety",
    "trust",
    "guardrails",
    "model-context-protocol"
  ],
  "author": "PDXLab",
  "license": "MIT",
  "dependencies": {
    "@microsoft/agent-governance-sdk": "^3.7.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "node-fetch": "^3.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist/"
  ]
}
