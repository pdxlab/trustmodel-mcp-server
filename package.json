{
  "name": "@trustmodel/mcp-server",
  "version": "0.2.0",
  "description": "TrustModel MCP Server — trust evaluation for AI agents via Model Context Protocol",
  "mcpName": "io.github.karlmehta/trustmodel-mcp",
  "type": "module",
  "homepage": "https://trustmodel.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karlmehta/trustmodel-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/karlmehta/trustmodel-mcp/issues"
  },
  "author": "Karl Mehta",
  "bin": {
    "trustmodel-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "verify:scanner": "npm run build && node scripts/verify-scanner.mjs",
    "verify:discovery": "npm run build && node scripts/verify-shadow-discovery.mjs",
    "verify:fingerprint": "npm run build && node scripts/verify-fingerprint.mjs",
    "verify:error-envelope": "npm run build && node scripts/verify-error-envelope.mjs",
    "verify:agentcert": "npm run build && node scripts/verify-agentcert.mjs",
    "verify:guardrails": "npm run build && node scripts/verify-guardrails.mjs",
    "regression:scanner": "npm run build && node regression/scanner.mjs",
    "smoke": "npm run build && node e2e/smoke.mjs"
  },
  "keywords": [
    "mcp",
    "trustmodel",
    "ai-safety",
    "trust",
    "guardrails",
    "model-context-protocol",
    "eval",
    "red-team",
    "governance",
    "compliance",
    "agent-evaluation",
    "trust-score"
  ],
  "license": "MIT",
  "dependencies": {
    "@microsoft/agent-governance-sdk": "^3.7.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "node-fetch": "^3.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist/"
  ]
}
